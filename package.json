{
    "name": "ai-prompt-vault-api",
    "version": "0.1.0",
    "description": "A REST API to manage AI prompts, built with Spec-Driven Development and hexagonal architecture.",
    "type": "module",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/index.js",
        "test": "vitest run --coverage",
        "test:unit": "vitest run --project unit",
        "test:integration": "vitest run --project integration",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix && prettier --write .",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "db:migrate": "drizzle-kit migrate"
    },
    "dependencies": {
        "@zxcvbn-ts/core": "^4.1.2",
        "@zxcvbn-ts/language-common": "^4.1.3",
        "@zxcvbn-ts/language-en": "^4.1.1",
        "bcrypt": "^6.0.0",
        "drizzle-orm": "^0.45.2",
        "express": "^5.1.0",
        "express-rate-limit": "^8.5.2",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.22.0",
        "zod": "^4.4.3",
        "zod-openapi": "^6.0.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.5.0",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.13.3",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "@vitest/coverage-v8": "^4.1.10",
        "drizzle-kit": "^0.31.10",
        "eslint": "^8.57.0",
        "eslint-import-resolver-typescript": "^3.6.1",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-import": "^2.29.1",
        "prettier": "^3.3.2",
        "supertest": "^7.0.0",
        "tsx": "^4.16.2",
        "typescript": "^5.5.3",
        "vitest": "^4.1.9",
        "vitest-mock-extended": "^4.0.0"
    },
    "allowScripts": {
        "bcrypt@6.0.0": true
    }
}
