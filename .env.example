ENVIRONMENT=development
PORT=3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=ai_prompts_vault
DATABASE_PASSWORD=
DATABASE_DB=ai_prompts_vault

JWT_SECRET=test-jwt-secret-for-local-development
